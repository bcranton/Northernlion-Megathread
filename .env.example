# Twitch API credentials (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Channel to monitor
TWITCH_CHANNEL=Northernlion

# Secret for verifying Twitch EventSub webhook signatures (generate a random string)
TWITCH_WEBHOOK_SECRET=your_random_webhook_secret

# Reddit API credentials (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=NorthernlionBot
REDDIT_PASSWORD=your_reddit_password

# Subreddit to post to (without r/ prefix)
SUBREDDIT=NLSSBotTest

# Public HTTPS URL where this app is hosted (for Twitch webhook callbacks)
BASE_URL=https://your-app.up.railway.app

# SQLite database path
DATABASE_PATH=data/bot.db

# Grace period (seconds) for reusing a thread after stream restart (default: 1800 = 30 min)
# RESTART_GRACE_PERIOD_SECONDS=1800
